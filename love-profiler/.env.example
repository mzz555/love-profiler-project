# Copy this file to .env and fill in real values before running the server.

# 开发模式：true 时启用 POST /auth/dev-login（无需抖音凭据），生产环境必须设为 false
DEV_MODE=false

# Doubao (豆包) LLM API
DOUBAO_API_KEY=your-doubao-api-key-here
DOUBAO_MODEL=doubao-pro-32k

# Douyin mini-program credentials
DOUYIN_APP_ID=your-appid-here
DOUYIN_APP_SECRET=your-appsecret-here

# Payment callback signature token (from ByteDance developer console)
DOUYIN_PAY_TOKEN=your-pay-token-here

# Incentive-ad verification secret (optional; skip verification if unset)
DOUYIN_AD_SECRET=

# JWT signing secret (use a long random string in production)
JWT_SECRET=change-me-in-production

# Database (SQLite for dev, PostgreSQL URL for prod)
DATABASE_URL=sqlite:///./love_profiler.db

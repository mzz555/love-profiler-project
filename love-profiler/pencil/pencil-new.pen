                        14
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "ssrJn",
                          "fill": "$green-deep",
                          "content": "“",
                          "lineHeight": 0.6,
                          "fontFamily": "$font-serif",
                          "fontSize": 30,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "oaH8E",
                          "fill": "$text-deep",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "你不是强势靠近的人，只是总能用温柔和回应，慢慢走进别人心里。",
                          "lineHeight": 1.85,
                          "fontFamily": "$font-serif",
                          "fontSize": 13,
                          "fontWeight": "normal",
                          "letterSpacing": 0.5
                        },
                        {
                          "type": "frame",
                          "id": "APV69",
                          "width": "fill_container",
                          "justifyContent": "end",
                          "children": [
                            {
                              "type": "text",
                              "id": "yOqvV",
                              "fill": "#D4A56C8C",
                              "content": "❀",
                              "fontFamily": "Inter",
                              "fontSize": 18,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "xJ5gh",
                      "name": "PortraitBody",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 10,
                      "children": [
                        {
                          "type": "text",
                          "id": "wI91c",
                          "fill": "$text-mid",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "你很少让关系一开始就充满压迫感。和你相处的人，往往会先感受到一种舒服——你不咄咄逼人，也不冷淡疏离，你更像一种慢慢靠近的温度，让人不知不觉就愿意多停留一点。",
                          "lineHeight": 1.85,
                          "fontFamily": "$font-sans",
                          "fontSize": "$fs-body",
                          "fontWeight": "normal",
                          "letterSpacing": 0.3
                        },
                        {
                          "type": "text",
                          "id": "W5LkN",
                          "fill": "$text-mid",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "你擅长的，不是轰轰烈烈地闯入别人世界，而是通过回应、理解、细节和耐心，让关系一点点变深。你会听、会接、会给出温柔的反馈，也因此常常成为那个让人想继续靠近的人。",
                          "lineHeight": 1.85,
                          "fontFamily": "$font-sans",
                          "fontSize": "$fs-body",
                          "fontWeight": "normal",
                          "letterSpacing": 0.3
                        },
                        {
                          "type": "text",
                          "id": "Sg33j",
                          "fill": "$text-mid",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "但你也容易在这种「自然流动」里，习惯先去照顾关系的气氛，而把自己的真实需要放得太轻。真正好的亲密，不只是你温暖地走向别人，也应该有人认真看见你、回应你，把温度送回你这里。",
                          "lineHeight": 1.85,
                          "fontFamily": "$font-sans",
                          "fontSize": "$fs-body",
                          "fontWeight": "normal",
                          "letterSpacing": 0.3
                        }
                      ]
                    }
                  ]
                }
              ]
            },
